      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "poc-prometheus"
          },
          "expr": "sum by (service, status) (rate(http_requests_total{service=~\"$service\",status=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{service}} {{status}}",
          "range": true,
          "refId": "H"
        }
      ]
    },
    {
      "id": 114,
      "type": "timeseries",
      "title": "Latency p95 by service",
      "datasource": {
        "type": "prometheus",
        "uid": "poc-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
