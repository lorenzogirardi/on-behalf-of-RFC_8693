{
  "uid": "poc-identity-flow",
  "title": "Agent Identity \u2014 Delegation Flow",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "tags": [
    "agent-identity-poc"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Exchange rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "poc-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "poc-prometheus"
          },
          "expr": "sum(rate(obo_exchange_total[5m]))",
          "legendFormat": "__auto",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fallback ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "poc-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "poc-prometheus"
          },
          "expr": "sum(rate(obo_exchange_total{result=\"fallback\"}[5m])) / sum(rate(obo_exchange_total[5m]))",
          "legendFormat": "__auto",
          "range": true,
          "refId": "E"
        }
      ]
    },
